{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"$CLAUDE_PROJECT_DIR/scripts/validate-mappings.py\" || true",
            "timeout": 30,
            "statusMessage": "Validating mappings invariants..."
          }
        ]
      }
    ]
  }
}
